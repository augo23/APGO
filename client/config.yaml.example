# Example client config. Copy to /config/client.yaml (or point CLIENT_CONFIG
# at it) and adjust. All nodes in one overlay must share network_name, psk,
# and overlay_cidr.

network_name: "home-lab-overlay"
node_private_key: "/config/node.key"
psk: "base64:r5D9QBcJw5ToR+Aq68aL/eSZzq6Cm7IWkW+T/ozzUaU="

# Overlay subnet. Each node derives its own stable IP inside this range from
# its public key — no per-node addressing needed. Can also be set with the
# OVERLAY_CIDR environment variable (env wins over this file).
overlay_cidr: "10.28.55.0/24"

tun:
  name: "ovl0"
  mtu: 1280
  # address_cidr: "10.28.55.2/24"   # optional: pin this node's IP manually

# Fixed port keeps the NAT mapping stable across restarts. 0 = random.
udp_listen_port: 6969

stun_servers:
  - "stun:stun.l.google.com:19302"
  - "stun:stun1.l.google.com:19302"
  - "stun:global.stun.twilio.com:3478"

announce_only_on_ip_change: false
tracker_list_file: "/config/trackers.txt"
controller_url: ""
min_announce_interval_seconds: 30

# Optional extras:
# trackers:                      # inline tracker URLs (udp:// or http://)
#   - "udp://tracker.opentrackr.org:1337/announce"
# static_peers:                  # known endpoints to dial immediately
#   - "203.0.113.7:6969"
# tracker_mode: "bootstrap"      # or "passive" (announce port 0, poll fast)
# compression: true
# exit_node: true                # BE an internet exit for the mesh (Linux only)
# use_exit: true                 # route ALL internet traffic via an exit (full VPN)
# exit_peer: "10.28.55.7"        # pin ONE exit (overlay IP / name / key); blank = fastest

# NAT keepalive interval (seconds). Default 10 (survives aggressive NATs);
# sessions self-heal after ~3 missed intervals. Clamped 5..120.
# keepalive_seconds: 10
