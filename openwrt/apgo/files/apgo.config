config apgo 'main'
	option enabled '0'
	# Same network name + PSK on every device on your mesh.
	option network_name ''
	option psk ''
	option friendly_name 'openwrt-router'
	option overlay_cidr '10.28.55.0/24'
	# Optional: pin this router's overlay IP (blank = derived from its key).
	option overlay_address ''
	option udp_listen_port '6969'
	option mtu '1280'
	# Keep the crypto profile identical network-wide.
	option post_quantum '1'
	option pq_auth '1'
	option ipv6 '1'
	# "chacha" (default, fast everywhere) or "aesgcm" (x86 with AES-NI).
	option cipher 'chacha'
	# Route all of this ROUTER's internet traffic via a mesh exit node:
	option use_exit '0'
	option exit_peer ''
	# Make this router an exit (internet outproxy) for the mesh — see
	# README "Exit node" for the firewall/NAT side:
	option exit_node '0'
	# Optional HTTPS rendezvous server URLs (space-separated), for networks
	# that block BitTorrent trackers:
	# option rendezvous_servers 'https://rendezvous.example.com'
