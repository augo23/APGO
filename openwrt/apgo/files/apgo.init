#!/bin/sh /etc/rc.common
# APGO overlay client — procd service for OpenWrt.
# Config: /etc/config/apgo (UCI). This script renders it to the same
# client.yaml the Docker container uses and supervises the client.

START=95
STOP=10
USE_PROCD=1

PROG=/usr/bin/overlay-client
STATE_DIR=/etc/apgo          # node key + managed state (persists across reboots)
RUN_DIR=/var/etc/apgo        # rendered config (rebuilt every start)
CONF=$RUN_DIR/client.yaml

render_config() {
	local network_name psk friendly overlay_cidr overlay_address
	local port mtu pq pq_auth ipv6 cipher use_exit exit_peer exit_node rendezvous

	config_load apgo
	config_get network_name main network_name
	config_get psk main psk
	config_get friendly main friendly_name 'openwrt-router'
	config_get overlay_cidr main overlay_cidr '10.28.55.0/24'
	config_get overlay_address main overlay_address
	config_get port main udp_listen_port '6969'
	config_get mtu main mtu '1280'
	config_get_bool pq main post_quantum 1
	config_get_bool pq_auth main pq_auth 1
	config_get_bool ipv6 main ipv6 1
	config_get cipher main cipher 'chacha'
	config_get_bool use_exit main use_exit 0
	config_get exit_peer main exit_peer
	config_get_bool exit_node main exit_node 0
	config_get rendezvous main rendezvous_servers

	[ -n "$network_name" ] && [ -n "$psk" ] || {
		echo "apgo: set network_name and psk in /etc/config/apgo" >&2
		return 1
	}

	mkdir -p "$STATE_DIR" "$RUN_DIR"
	{
		echo "network_name: \"$network_name\""
		echo "psk: \"$psk\""
		echo "friendly_name: \"$friendly\""
		echo "node_private_key: \"$STATE_DIR/node.key\""
		echo "overlay_cidr: \"$overlay_cidr\""
		echo "udp_listen_port: $port"
		echo "keepalive_seconds: 10"
		echo "tun:"
		echo "  name: \"ovl0\""
		echo "  mtu: $mtu"
		[ -n "$overlay_address" ] && echo "  address_cidr: \"$overlay_address\""
		[ "$pq" = 1 ] && echo "post_quantum: true" || echo "post_quantum: false"
		[ "$pq_auth" = 1 ] && echo "pq_auth: true" || echo "pq_auth: false"
		[ "$ipv6" = 1 ] && echo "ipv6: true" || echo "ipv6: false"
		echo "cipher: \"$cipher\""
		[ "$use_exit" = 1 ] && echo "use_exit: true"
		[ -n "$exit_peer" ] && echo "exit_peer: \"$exit_peer\""
		[ "$exit_node" = 1 ] && echo "exit_node: true"
		if [ -n "$rendezvous" ]; then
			echo "rendezvous_servers:"
			for r in $rendezvous; do echo "  - \"$r\""; done
		fi
		echo "stun_servers:"
		echo "  - \"stun:stun.l.google.com:19302\""
		echo "  - \"stun:stun1.l.google.com:19302\""
	} > "$CONF"
}

start_service() {
	local enabled
	config_load apgo
	config_get_bool enabled main enabled 0
	[ "$enabled" = 1 ] || return 0

	render_config || return 1

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param env \
		CLIENT_CONFIG="$CONF" \
		ADMIN_PUBKEY_FILE="$STATE_DIR/admin-pubkey" \
		PROVISIONS_FILE="$STATE_DIR/provisions.json" \
		REVOCATIONS_FILE="$STATE_DIR/revocations.json" \
		SEALED_ADMIN_KEY_FILE="$STATE_DIR/admin-key-sealed.json" \
		APPROVALS_FILE="$STATE_DIR/approvals.json" \
		NETCONFIG_FILE="$STATE_DIR/netconfig.json" \
		TRACKERS_FILE="$STATE_DIR/trackers.txt" \
		POLICY_FILE="$STATE_DIR/policy.json"
	procd_set_param respawn 300 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "apgo"
}

reload_service() {
	stop
	start
}
